# Database (Neon Postgres)
# Define DATABASE_URL once only. For hosted Postgres, include sslmode=verify-full.
# For local Postgres, sslmode can usually be omitted.
DATABASE_URL=

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=   # Generate with: npx -y @better-auth/cli secret

# GitHub OAuth (for Better Auth social login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Trigger.dev
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

# Electric Cloud (Postgres Sync)
ELECTRIC_URL=https://api.electric-sql.cloud
ELECTRIC_SOURCE_ID=
ELECTRIC_SECRET=

# Encryption key for user provider keys (32-byte base64 or 64-char hex)
OPENCODER_KEYS_MASTER_KEY=

# GitHub App (webhook verification)
GITHUB_APP_WEBHOOK_SECRET=
